# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GOOGLE_SERVICE_ACCOUNT_JSON: The JSON string of your Google Service Account key.
# Required for Google Calendar API integration.
GOOGLE_SERVICE_ACCOUNT_JSON='{"type": "service_account", ...}'

# GOOGLE_CALENDAR_ID: The ID of the primary calendar to sync with (optional if using per-barber calendars).
GOOGLE_CALENDAR_ID="your_calendar_id@group.calendar.google.com"
